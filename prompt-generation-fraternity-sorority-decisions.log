<parameter name="old_string">    id: 'prompt-33',
    prompt: 'Research each organization\'s mandatory new member education program requirements and timeline to understand your semester commitments',
    category: 'planning',
    helpText: 'New member education programs vary significantly between organizations and can involve substantial time commitments including weekly meetings, community service hours, and educational activities throughout your pledge period. Contact each organization\'s new member educator to get specific details about program length, weekly time requirements, academic expectations, and major events or activities you\'ll need to plan around. Understanding these commitments helps you prepare academically and personally for the intensive new member period while ensuring you can successfully balance these requirements with your existing responsibilities.'
  }
];</parameter>
<parameter name="new_string">    id: 'prompt-33',
    prompt: 'Research each organization\'s mandatory new member education program requirements and timeline to understand your semester commitments',
    category: 'planning',
    helpText: 'New member education programs vary significantly between organizations and can involve substantial time commitments including weekly meetings, community service hours, and educational activities throughout your pledge period. Contact each organization\'s new member educator to get specific details about program length, weekly time requirements, academic expectations, and major events or activities you\'ll need to plan around. Understanding these commitments helps you prepare academically and personally for the intensive new member period while ensuring you can successfully balance these requirements with your existing responsibilities.'
  },
  {
    id: 'prompt-34',
    prompt: 'Create and submit your formal preference card or application materials with ranked organization choices before the recruitment deadline',
    category: 'action',
    helpText: 'Submitting your formal application materials accurately and on time is critical for participating in the final selection process and demonstrates your serious commitment to joining Greek life. Review all application requirements carefully, including personal statements, transcripts, recommendation letters, and preference rankings, ensuring everything is complete and submitted before the strict deadline. This final step transitions you from the research and preparation phase into the formal selection process where organizations make their membership decisions.'
  }
];</parameter>
</invoke>
