// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// User account and authentication
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth.js relations
  accounts Account[]
  sessions Session[]

  // User's template progress and data
  templateSessions TemplateSession[]
  userResponses    UserResponse[]
  savedResources   SavedResource[]

  @@map("users")
}

// Individual template session (when user starts working on a template)
model TemplateSession {
  id         String   @id @default(cuid())
  userId     String
  templateId String   // ID from template registry (e.g., 'wedding-planning')
  title      String   // Template title for easy reference
  startedAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  // Session metadata
  isCompleted Boolean @default(false)
  progress    Float   @default(0.0) // 0.0 to 1.0
  currentSection String?  // Current section user is working on
  
  // JSON data for flexibility
  metadata   Json?    // Store additional session data
  
  // Relations
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses UserResponse[]

  @@map("template_sessions")
}

// User responses to reflection prompts
model UserResponse {
  id        String   @id @default(cuid())
  userId    String
  sessionId String
  templateId String   // For easier querying
  sectionId  String   // Section within template
  promptId   String   // Specific prompt ID
  
  // Response data
  response  String   // User's written response
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Additional metadata
  metadata  Json?    // Store additional response data
  
  // Relations
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  session TemplateSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, promptId]) // Prevent duplicate responses for same prompt in session
  @@map("user_responses")
}

// Saved resources for later reference
model SavedResource {
  id         String   @id @default(cuid())
  userId     String
  templateId String
  resourceId String   // Resource ID from template
  title      String   // Resource title for easy reference
  savedAt    DateTime @default(now())
  
  // Optional notes from user
  userNotes  String?
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId]) // Prevent duplicate saves
  @@map("saved_resources")
}
