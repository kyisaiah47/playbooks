<parameter name="old_string">  {
    id: 'prompt-50',
    prompt: 'Create and fund a separate "post-graduation transition fund" with $2,000-3,000 for job search expenses, professional wardrobe, and first apartment setup',
    category: 'action',
    helpText: 'Building a transition fund prevents you from accumulating high-interest debt during the critical period between college and your first steady paycheck. Include costs for interview travel, professional clothing, security deposits, moving expenses, and 1-2 months of living expenses in case your job start date is delayed. Having this fund ready allows you to focus on landing the best possible job offer rather than accepting the first opportunity due to financial pressure, potentially increasing your starting salary and accelerating your FIRE timeline from day one of your career.'
  }
];</parameter>
<parameter name="new_string">  {
    id: 'prompt-50',
    prompt: 'Create and fund a separate "post-graduation transition fund" with $2,000-3,000 for job search expenses, professional wardrobe, and first apartment setup',
    category: 'action',
    helpText: 'Building a transition fund prevents you from accumulating high-interest debt during the critical period between college and your first steady paycheck. Include costs for interview travel, professional clothing, security deposits, moving expenses, and 1-2 months of living expenses in case your job start date is delayed. Having this fund ready allows you to focus on landing the best possible job offer rather than accepting the first opportunity due to financial pressure, potentially increasing your starting salary and accelerating your FIRE timeline from day one of your career.'
  },
  {
    id: 'prompt-51',
    prompt: 'Schedule and complete your first post-graduation performance review preparation meeting with a mentor or career counselor',
    category: 'action',
    helpText: 'Proactively preparing for your first annual performance review can result in earlier promotions and salary increases that significantly accelerate your FIRE timeline. Meet with a mentor, career counselor, or trusted professional to practice articulating your accomplishments, setting ambitious but realistic goals, and negotiating compensation increases. Early career salary growth is often the steepest and most impactful for long-term wealth building, making performance review preparation one of the highest-return activities for new graduates focused on financial independence.'
  }
];</parameter>
</invoke>
