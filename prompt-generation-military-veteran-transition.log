<invoke name="Edit">
<parameter name="file_path">/Users/ikim1/Documents/GitHub/templata-military-veteran-transition/src/data/prompts-military-veteran-transition.ts</parameter>
<parameter name="old_string">  {
    id: 'prompt-41',
    prompt: 'Contact and schedule informational interviews with 5 civilian hiring managers in your target industry to understand their veteran recruitment perspectives',
    category: 'action',
    helpText: 'Understanding how civilian hiring managers perceive military experience helps you tailor your application materials and interview approach to address their specific concerns and highlight your most relevant qualifications. Many civilian managers have misconceptions about military experience or don\'t understand how to evaluate military skills, so these conversations provide critical insights into what resonates with decision-makers. Use these interviews to practice translating your military experience into civilian terms while building relationships that could lead to job opportunities or valuable referrals.'
  }</parameter>
<parameter name="new_string">  {
    id: 'prompt-41',
    prompt: 'Contact and schedule informational interviews with 5 civilian hiring managers in your target industry to understand their veteran recruitment perspectives',
    category: 'action',
    helpText: 'Understanding how civilian hiring managers perceive military experience helps you tailor your application materials and interview approach to address their specific concerns and highlight your most relevant qualifications. Many civilian managers have misconceptions about military experience or don\'t understand how to evaluate military skills, so these conversations provide critical insights into what resonates with decision-makers. Use these interviews to practice translating your military experience into civilian terms while building relationships that could lead to job opportunities or valuable referrals.'
  },
  {
    id: 'prompt-42',
    prompt: 'Register for 3 professional associations or industry groups relevant to your target civilian career field',
    category: 'action',
    helpText: 'Professional association membership demonstrates your commitment to your new career field and provides access to industry resources, continuing education, and networking opportunities that are crucial for long-term success. Many associations offer veteran discounts or special transition programs that include mentorship, job boards, and industry certification pathways. Active participation in professional organizations helps you stay current with industry trends, build credibility with civilian colleagues, and access insider knowledge about career advancement opportunities that aren\'t available through general job search channels.'
  }</parameter>
</invoke>
