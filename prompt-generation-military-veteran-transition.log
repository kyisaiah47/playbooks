<parameter name="old_string">  {
    id: 'prompt-32',
    prompt: 'Complete a comprehensive education benefits briefing and submit your Certificate of Eligibility (COE) application for GI Bill benefits',
    category: 'action',
    helpText: 'Understanding the full scope of your education benefits and obtaining your COE is essential for accessing education funding and planning your career development timeline. The COE process can take several weeks and is required before you can enroll in educational programs or training courses using your GI Bill benefits. Schedule your education benefits briefing early in your transition to understand different benefit options, transfer possibilities to family members, and how to maximize your education funding for long-term career success.'
  }
];</parameter>
<parameter name="new_string">  {
    id: 'prompt-32',
    prompt: 'Complete a comprehensive education benefits briefing and submit your Certificate of Eligibility (COE) application for GI Bill benefits',
    category: 'action',
    helpText: 'Understanding the full scope of your education benefits and obtaining your COE is essential for accessing education funding and planning your career development timeline. The COE process can take several weeks and is required before you can enroll in educational programs or training courses using your GI Bill benefits. Schedule your education benefits briefing early in your transition to understand different benefit options, transfer possibilities to family members, and how to maximize your education funding for long-term career success.'
  },
  {
    id: 'prompt-33',
    prompt: 'Develop a detailed post-separation career development plan with specific skill-building milestones for your first 12 months in civilian employment',
    category: 'planning',
    helpText: 'Creating a structured professional development roadmap helps you continue growing in your civilian career and demonstrates career commitment to employers who invest in veteran talent. Map out specific skills you need to develop, industry certifications to pursue, and professional relationships to build during your first year to accelerate your career progression. This proactive approach positions you for advancement opportunities and salary increases while building confidence in your new civilian role through continuous improvement and measurable achievements.'
  }
];</parameter>
</invoke>
